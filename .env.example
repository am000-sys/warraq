# ════════════════════════════════════════
# وَرَّاق — متغيّرات البيئة
# انسخ هذا الملفّ إلى .env.local واملأ القيم
# ════════════════════════════════════════

# ── أساسيّ (مطلوب للتشغيل) ──
# قاعدة بيانات PostgreSQL. على Supabase استعمل Transaction Pooler (المنفذ 6543)
# مع pgbouncer للبيئات serverless مثل Vercel:
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# سرّ NextAuth — ولّده بـ: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="..."
# على Vercel يُضبط تلقائياً؛ محلّياً: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ── حساب المالك (يُستخدم في npm run db:seed فقط) ──
SEED_ADMIN_EMAIL="you@example.com"
SEED_ADMIN_PASSWORD="كلمة-مرور-قوية-10-أحرف-فأكثر"
SEED_ADMIN_NAME="اسمك"

# ── Mistral OCR (خدمة التفريغ النصّي الأساسيّة — مفضّلة) ──
# من: https://console.mistral.ai/api-keys
# عند ضبطها يُستخدم Mistral للتفريغ؛ وإلّا يرجع النظام إلى Claude.
MISTRAL_API_KEY="..."

# ── Claude (بديل للتفريغ + خدمات Ask/Report الإضافيّة المدفوعة) ──
# نفس المفتاح يشغّل المعالجة وخدمات Claude الإضافيّة. إعداد الإضافة (تفعيل/سعر/طريقة
# الاحتساب) يُدار من جدول SystemSetting (مفاتيح claude_addon_*) لا من البيئة.
# من: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── Qwen (مزوّد مجانيّ/أرخص للملخّص الدراسي — بديل اختياريّ لـ Claude) ──
# يُستخدم فقط في ميزة «الملخّص الدراسي» عندما يضبط المالك study_model على معرّف
# يبدأ بـ qwen- (مثل qwen-plus). ميزات OCR وAsk/Report لا تتأثّر.
# من: https://bailian.console.alibabacloud.com (DashScope API Keys)
QWEN_API_KEY=""
# القاعدة الدوليّة افتراضاً؛ لقاعدة الصين: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
# أقصى توكنات إخراج للنداء الواحد (المتابعة تُكمل تلقائيّاً إن بُلغ الحدّ)
QWEN_MAX_OUTPUT="8192"

# ── التخزين Cloudflare R2 (مطلوب لرفع الملفّات فعلياً) ──
# من: dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="warraq"

# ── الدفع: Stripe (بطاقات دوليّة + Apple/Google Pay) ──
# من: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── الدفع: Tap Payments (مدى + Apple Pay سعودي + STC Pay) ──
# من: dashboard.tap.company
TAP_SECRET_KEY=""

# سعر الصفحة في الدفع لمرّة واحدة (بالهللات) — افتراضي ٣١ هللة
PAYG_PRICE_HALALA="31"

# ── البريد Resend (اختياري — لاستعادة كلمة المرور) ──
RESEND_API_KEY=""
EMAIL_FROM="warraq <noreply@yourdomain.com>"
