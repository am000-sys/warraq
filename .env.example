# ════════════════════════════════════════════════
# Warraq · متغيّرات البيئة
# ════════════════════════════════════════════════
# انسخ هذا الملف إلى .env.local ثمّ ضع القيم الفعليّة.

# ─── ١. أساسيات التطبيق ─────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── ٢. قاعدة البيانات (Postgres) ───────────────
# للتطوير: Supabase (مجاني) أو Neon (مجاني) أو Railway
DATABASE_URL="postgresql://user:password@host:5432/warraq?schema=public"

# ─── ٣. المصادقة (Auth.js) ──────────────────────
# اِنشئ سرّاً قويّاً: openssl rand -base64 32
AUTH_SECRET="ضع-سلسلة-عشوائية-طويلة-32-حرفاً-فأكثر"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (اختياري - يُفعَّل تلقائياً لو وُجد)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ════════════════════════════════════════════════
# ⭐ ٤. حساب المالك (System Admin) — مهمّ جدّاً
# ════════════════════════════════════════════════
# هذه القيم تُستخدم لمرّة واحدة فقط حين تشغّل:
#     npm run db:seed
#
# بعد ذلك ادخل من /login بهذا البريد وكلمة المرور.
# ───────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMeStrongPassword123"
SEED_ADMIN_NAME="اسمك الكامل"
# ────────────────────────────────────────────────

# ─── ٥. Anthropic Claude API ────────────────────
# من: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── ٦. Stripe (دفعات دوليّة + Apple/Google Pay) ─
# من: https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── ٧. Tap Payments (مدى + Apple Pay سعودي + STC) ─
# من: https://www.tap.company
TAP_SECRET_KEY="sk_test_..."
TAP_PUBLIC_KEY="pk_test_..."
TAP_WEBHOOK_SECRET=""

# ─── ٨. Cloudflare R2 (تخزين الملفات) ───────────
# من: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="warraq-uploads"
R2_PUBLIC_URL=""

# ─── ٩. Resend (البريد الإلكتروني) ──────────────
# من: https://resend.com
RESEND_API_KEY="re_..."
EMAIL_FROM="warraq@yourdomain.com"

# ─── ١٠. الإعدادات التشغيلية ────────────────────
PAYG_PRICE_PER_PAGE_HALALA="25"
RESULTS_RETENTION_DAYS="30"
MAX_PAGES_PER_FILE="2000"
MAX_FILE_SIZE_MB="100"
